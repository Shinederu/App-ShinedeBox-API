BASE_URL=https://box.shinederu.ch
BOX_API_BASE=https://api.shinederu.ch/box
AUTH_PORTAL_URL=https://auth.shinederu.ch
AUTH_API_BASE=https://api.shinederu.ch/auth/

DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ShinedeCore
DB_USER=authenticator
DB_PASS=change_me

# Optional dedicated DB credentials for this API
BOX_DB_TYPE=
BOX_DB_HOST=
BOX_DB_PORT=
BOX_DB_NAME=
BOX_DB_USER=
BOX_DB_PASS=

UPLOAD_DIR=/var/www/ShinedeBoxStorage/files
MAX_FILE_MB=20480
ALLOWED_EXT=*
BLOCKED_EXT=.php,.phtml,.phar,.cgi,.pl,.py,.sh,.bash,.exe,.bat,.cmd,.com,.msi,.dll,.so
ALLOWED_MIME=*
